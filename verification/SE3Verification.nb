Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "==="}], " ", "*)"}], "\n", 
  RowBox[{"(*", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"PART", " ", "15"}], ":", " ", 
     RowBox[{
     "PHASE", " ", "REFLECTION", " ", "BOUNDARY", " ", "AT", " ", "THETA"}]}],
     " ", "=", " ", "PI"}], "                        ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "==="}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<\\n\\n================================================================\>\
\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<PART 15: Phase reflection at Theta = pi\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<================================================================\>\"", 
     "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"R", 
      RowBox[{"(", 
       RowBox[{"r", ",", " ", "pi"}], ")"}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"R", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "r"}], ",", " ", "pi"}], ")"}], " ", "means", " ", 
        "the", " ", "Rodrigues", " ", "vector", " ", "is", " ", "ambiguous", " ",
         "at"}], " ", "|", "Omega", "|"}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"pi", ".", "\n", "   ", "The"}], " ", "cutline", " ", "in", " ",
         "the", " ", "SU", 
        RowBox[{"(", "2", ")"}], " ", 
        RowBox[{"parametrization", ":", " ", 
         RowBox[{"cos", 
          RowBox[{"(", "vartheta", ")"}]}]}]}], " ", "=", " ", "0."}]}]}], 
    " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Test", ":", " ", 
     RowBox[{
     "compose", " ", "two", " ", "large", " ", "rotations", " ", "crossing", " ",
       "pi"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"omA", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"2.8", ",", " ", "0.", ",", " ", "0."}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"omB", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"0.8", ",", " ", "0.", ",", " ", "0."}], "}"}]}], ";"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Sum", " ", "=", " ", 
      RowBox[{"3.6", " ", ">", " ", "pi"}]}], ",", " ", 
     RowBox[{
      RowBox[{"so", " ", "the", " ", "result", " ", "must", " ", "phase"}], "-",
       "reflect"}]}], " ", "*)"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Rc", " ", "=", " ", 
     RowBox[{
      RowBox[{"rodriguesExp", "[", "omA", "]"}], " ", ".", " ", 
      RowBox[{"rodriguesExp", "[", "omB", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"omCmat", " ", "=", " ", 
     RowBox[{"rodriguesLog", "[", "Rc", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"omCbch", " ", "=", " ", 
     RowBox[{"bchCompose", "[", 
      RowBox[{"omA", ",", " ", "omB"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Omega_a = \>\"", ",", " ", "omA", ",", 
      " ", "\"\< (theta_a = \>\"", ",", " ", 
      RowBox[{
       RowBox[{"Norm", "[", "omA", "]"}], " ", "//", " ", "N"}], ",", 
      " ", "\"\<)\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Omega_b = \>\"", ",", " ", "omB", ",", 
      " ", "\"\< (theta_b = \>\"", ",", " ", 
      RowBox[{
       RowBox[{"Norm", "[", "omB", "]"}], " ", "//", " ", "N"}], ",", 
      " ", "\"\<)\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Naive sum = \>\"", ",", " ", 
      RowBox[{
       RowBox[{"Norm", "[", 
        RowBox[{"omA", " ", "+", " ", "omB"}], "]"}], " ", "//", " ", "N"}], ",",
       " ", "\"\< > pi\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Matrix log: Omega_c = \>\"", ",", " ", "omCmat", ",", 
      " ", "\"\< (theta_c = \>\"", ",", " ", 
      RowBox[{
       RowBox[{"Norm", "[", "omCmat", "]"}], " ", "//", " ", "N"}], ",", 
      " ", "\"\<)\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<BCH:        Omega_c = \>\"", ",", " ", "omCbch", ",", 
      " ", "\"\< (theta_c = \>\"", ",", " ", 
      RowBox[{
       RowBox[{"Norm", "[", "omCbch", "]"}], " ", "//", " ", "N"}], ",", 
      " ", "\"\<)\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Expected theta_c = 2pi - 3.6 = \>\"", ",", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"2", " ", "Pi"}], " ", "-", " ", "3.6"}], " ", "//", " ", 
       "N"}]}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Verify", " ", "R", " ", "matrices", " ", "match"}], " ", "*)"}], 
   "\n", 
   RowBox[{
    RowBox[{"RcBCH", " ", "=", " ", 
     RowBox[{"rodriguesExp", "[", "omCbch", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<R matrices agree: max err = \>\"", ",", "\n", "  ", 
      RowBox[{
       RowBox[{"Max", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Rc", " ", "-", " ", "RcBCH"}], "]"}], "]"}], "]"}], " ", "//",
        " ", 
       RowBox[{
        RowBox[{"ScientificForm", "[", 
         RowBox[{"#", ",", " ", "3"}], "]"}], " ", "&"}]}]}], "]"}], 
    ";"}]}]}]], "Input",
