Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "==="}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"PART", " ", "3"}], ":", 
     RowBox[{"S", " ", "MATRIX"}]}], "\[LongDash]", 
    RowBox[{
    "translation", " ", "coupling", " ", "in", " ", "exponential", " ", 
     "map"}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "==="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<\\n\\n================================================================\>\
\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<PART 3: S matrix \[LongDash] T = S(Omega) t\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<================================================================\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"S", "=", 
     RowBox[{"I", "+", 
      RowBox[{"H", "^", "2"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "Theta"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"I", "-", "R"}], ")"}], " ", "H"}]}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Using", " ", "H", " ", 
      RowBox[{"algebra", ":", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"I", "-", "R"}], ")"}], "H"}]}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", "sin"}], 
        RowBox[{"(", "Theta", ")"}], 
        RowBox[{"H", "^", "2"}]}], "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"cos", 
           RowBox[{"(", "Theta", ")"}]}]}], ")"}], 
        RowBox[{"H", "^", "3"}]}]}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"-", "sin"}], 
         RowBox[{"(", "Theta", ")"}], 
         RowBox[{"H", "^", "2"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"cos", 
            RowBox[{"(", "Theta", ")"}]}]}], ")"}], "H", " ", "So", " ", 
         "S"}]}], "=", 
       RowBox[{
        RowBox[{"I", "+", 
         RowBox[{"H", "^", "2"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "/", "Theta"}], ")"}], "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "sin"}], 
            RowBox[{"(", "Theta", ")"}], 
            RowBox[{"H", "^", "2"}]}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"cos", 
               RowBox[{"(", "Theta", ")"}]}]}], ")"}], "H"}]}], "]"}]}], "=", 
        
        RowBox[{"I", "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"sin", 
             RowBox[{
              RowBox[{"(", "Theta", ")"}], "/", "Theta"}]}]}], ")"}], 
          RowBox[{"H", "^", "2"}]}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"cos", 
               RowBox[{"(", "Theta", ")"}]}]}], ")"}], "/", "Theta"}], ")"}], 
          "H"}]}]}]}]}]}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Ssym", "=", 
     RowBox[{
      RowBox[{"id3", "+", 
       RowBox[{"H", ".", "H"}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "theta"}], ")"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"id3", "-", "Rsym"}], ")"}], ".", "H"}]}]}], "//", 
      "Simplify"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Alternative", " ", "form"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Sform2", "=", 
     RowBox[{
      RowBox[{"id3", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"Sin", "[", "theta", "]"}], "/", "theta"}]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"H", ".", "H"}], ")"}]}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"Cos", "[", "theta", "]"}]}], ")"}], "/", "theta"}], 
         ")"}], " ", "H"}]}], "//", "Simplify"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<S two forms agree: \>\"", ",", 
      RowBox[{
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"Ssym", "-", "Sform2"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"r1", "^", "2"}], "+", 
           RowBox[{"r2", "^", "2"}], "+", 
           RowBox[{"r3", "^", "2"}]}], "==", "1"}]}], "]"}], "==", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", "3", "}"}], ",", 
         RowBox[{"{", "3", "}"}]}], "]"}]}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Verify", " ", "S", " ", "is", " ", 
     RowBox[{"invertible", ":", 
      RowBox[{"det", " ", "S"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"detS", "=", 
     RowBox[{
      RowBox[{"Det", "[", "Ssym", "]"}], "//", "Simplify"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<det S (symbolic): \>\"", ",", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{"detS", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"r1", "^", "2"}], "+", 
          RowBox[{"r2", "^", "2"}], "+", 
          RowBox[{"r3", "^", "2"}]}], "==", "1"}]}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"S", "^", 
     RowBox[{"{", 
      RowBox[{"-", "1"}], "}"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Paper", " ", 
       RowBox[{"Eq", ".", 
        RowBox[{"(", "Sinvidentity", ")"}]}]}], ":", 
      RowBox[{"S", "^", 
       RowBox[{"{", 
        RowBox[{"-", "1"}], "}"}]}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}], "I"}], "+", 
      RowBox[{"x", " ", "r", " ", 
       RowBox[{"r", "^", "T"}]}], "-", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "2"}], ")"}], "[", "Omega", "]"}], "_x"}]}]}], 
    "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"where", " ", "1"}], "-", "x"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Theta", "/", "2"}], ")"}], "/", "tan"}], 
       RowBox[{"(", 
        RowBox[{"Theta", "/", "2"}], ")"}]}], "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Theta", "/", "2"}], ")"}], " ", "cot", 
       RowBox[{"(", 
        RowBox[{"Theta", "/", "2"}], ")"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", "x", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"oneMinusX", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"theta", "/", "2"}], ")"}], "/", 
      RowBox[{"Tan", "[", 
       RowBox[{"theta", "/", "2"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xVal", "=", 
     RowBox[{"1", "-", "oneMinusX"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SinvClaimed", "=", 
     RowBox[{
      RowBox[{"oneMinusX", " ", "id3"}], "+", 
      RowBox[{"xVal", " ", "rrT"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"theta", "/", "2"}], ")"}], " ", "H"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Check", " ", 
      RowBox[{"S", ".", 
       RowBox[{"S", "^", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}]}]}], "=", "I"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SSinv", "=", 
     RowBox[{
      RowBox[{"Ssym", ".", "SinvClaimed"}], "//", "Simplify"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\\nS . S^{-1} = I: \>\"", ",", 
      RowBox[{
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"SSinv", "-", "id3"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"r1", "^", "2"}], "+", 
