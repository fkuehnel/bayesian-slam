       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", "Omega"}], ")"}], "--"}], "--"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"JwrNeg", "=", 
     RowBox[{
      RowBox[{"oneMinusX", " ", "id3"}], "+", 
      RowBox[{"xVal", " ", "rrT"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"theta", "/", "2"}], ")"}], " ", "H"}]}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"flip", " ", "sign", " ", "of", " ", "H", " ", "term"}], "*)"}], "\n", 
