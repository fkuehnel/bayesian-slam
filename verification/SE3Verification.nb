Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "==="}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"PART", " ", "14"}], ":", 
    RowBox[{"SECOND", "-", 
     RowBox[{"ORDER", " ", "COVARIANCE", " ", "CORRECTION", " ", 
      RowBox[{"(", 
       RowBox[{"Paper", " ", "Appendix", " ", "D"}], ")"}]}]}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "==="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<\\n\\n================================================================\>\
\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<PART 14: Second-order covariance correction\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<================================================================\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"The", " ", "BCH", " ", 
       RowBox[{"map", ":", "Omega_c"}]}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Omega_a", "+", "Omega_b", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", "2"}], ")"}], " ", "Omega_a", " ", "x", " ", 
           "Omega_b"}], "+"}], "..."}], " ", "For", " ", "zero"}], "-", 
       RowBox[{"mean", " ", "perturbations", " ", "delta_a"}]}]}], ",", 
     RowBox[{
      RowBox[{"delta_b", ":", "\[IndentingNewLine]", 
       RowBox[{"<", "Omega_c", ">"}]}], " ", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "2"}], ")"}], "<", 
        RowBox[{"delta_a", " ", "x", " ", "delta_b"}], ">"}], " ", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}], " ", "eps_", 
          RowBox[{"{", 
           RowBox[{"i", ",", "alpha", ",", "beta"}], "}"}], " ", "Sigma_ab", 
          "_", 
          RowBox[{"{", 
           RowBox[{"alpha", ",", "beta"}], "}"}], " ", "Covariance", " ", 
          "correction", " ", 
          RowBox[{"(", 
           RowBox[{"rotational", " ", "block"}], ")"}]}], ":", 
         RowBox[{"Delta", " ", "Sigma_ij"}]}], "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "4"}], ")"}], " ", "eps_", 
         RowBox[{"{", 
          RowBox[{"i", ",", "ab"}], "}"}], " ", "eps_", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"j", ",", "cd"}], "}"}], "[", 
          RowBox[{
           RowBox[{"Sigma_aa", "_", 
            RowBox[{"{", "ac", "}"}], " ", "Sigma_bb", "_", 
            RowBox[{"{", "bd", "}"}]}], "+", 
           RowBox[{"Sigma_ab", "_", 
            RowBox[{"{", "ad", "}"}], " ", "Sigma_ba", "_", 
            RowBox[{"{", "bc", "}"}]}]}], "]"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"using", " ", 
            RowBox[{"Isserlis", "'"}], " ", "theorem", " ", "for", " ", 
            "Gaussian", " ", "perturbations"}], "\[LongDash]", 
           RowBox[{
            RowBox[{"fourth", " ", "cumulant"}], "=", "0"}]}], 
          ")"}]}]}]}]}]}], "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Test", " ", "with", " ", "specific", " ", "covariances"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SigAA", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0.04", ",", "0.01", ",", 
         RowBox[{"-", "0.005"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0.01", ",", "0.03", ",", "0.008"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "0.005"}], ",", "0.008", ",", "0.05"}], "}"}]}], 
      "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"SigBB", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0.03", ",", 
         RowBox[{"-", "0.01"}], ",", "0.002"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "0.01"}], ",", "0.06", ",", 
         RowBox[{"-", "0.003"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0.002", ",", 
         RowBox[{"-", "0.003"}], ",", "0.04"}], "}"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"SigAB", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0.005", ",", 
         RowBox[{"-", "0.002"}], ",", "0.001"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0.003", ",", 
         RowBox[{"-", "0.004"}], ",", "0.002"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "0.001"}], ",", "0.003", ",", 
         RowBox[{"-", "0.002"}]}], "}"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"SigBA", "=", 
     RowBox[{"Transpose", "[", "SigAB", "]"}]}], ";"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", 
    RowBox[{"Mean", " ", "correction"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"LeviCivita", "[", 
      RowBox[{"i_", ",", "j_", ",", "k_"}], "]"}], ":=", 
     RowBox[{"Signature", "[", 
      RowBox[{"{", 
       RowBox[{"i", ",", "j", ",", "k"}], "}"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"meanCorr", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "2"}], ")"}], " ", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"LeviCivita", "[", 
            RowBox[{"i", ",", "a", ",", "b"}], "]"}], " ", 
           RowBox[{"SigAB", "[", 
            RowBox[{"[", 
             RowBox[{"a", ",", "b"}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"a", ",", "3"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"b", ",", "3"}], "}"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "3"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Second-order mean correction: \>\"", ",", 
      RowBox[{"meanCorr", "//", "N"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<(Should be nonzero if Sigma_ab has antisymmetric part)\
\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Covariance", " ", "correction"}], "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"DeltaSig", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "4"}], ")"}], " ", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"LeviCivita", "[", 
            RowBox[{"i", ",", "a", ",", "b"}], "]"}], " ", 
           RowBox[{"LeviCivita", "[", 
            RowBox[{"j", ",", "c", ",", "d"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"SigAA", "[", 
               RowBox[{"[", 
                RowBox[{"a", ",", "c"}], "]"}], "]"}], " ", 
              RowBox[{"SigBB", "[", 
               RowBox[{"[", 
                RowBox[{"b", ",", "d"}], "]"}], "]"}]}], "+", 
             RowBox[{
              RowBox[{"SigAB", "[", 
               RowBox[{"[", 
                RowBox[{"a", ",", "d"}], "]"}], "]"}], " ", 
              RowBox[{"SigBA", "[", 
               RowBox[{"[", 
                RowBox[{"b", ",", "c"}], "]"}], "]"}]}]}], ")"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"a", ",", "3"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"b", ",", "3"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"c", ",", "3"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"d", ",", "3"}], "}"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "3"}], "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\nSecond-order covariance correction (rotational \
block):\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{
      RowBox[{"DeltaSig", "//", "N"}], "//", "MatrixForm"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Verify", " ", "symmetry"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Symmetric: \>\"", ",", 
      RowBox[{"DeltaSig", "==", 
       RowBox[{"Transpose", "[", "DeltaSig", "]"}]}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Monte", " ", "Carlo", " ", "verification"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Monte Carlo verification ---\>\"", "]"}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"nSamples", "=", "100000"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Build", " ", "joint", " ", "covariance"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SigJoint", "=", 
     RowBox[{"ArrayFlatten", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"SigAA", ",", "SigAB"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"SigBA", ",", "SigBB"}], "}"}]}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cholJ", "=", 
     RowBox[{
      RowBox[{"CholeskyDecomposition", "[", "SigJoint", "]"}], "//", 
      "Transpose"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", "Sample", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"samples", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"cholJ", ".", 
        RowBox[{"RandomVariate", "[", 
         RowBox[{
          RowBox[{"NormalDistribution", "[", "]"}], ",", "6"}], "]"}]}], ",", 
       
       RowBox[{"{", "nSamples", "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Compose", " ", "via", " ", "BCH", " ", "second"}], "-", 
      RowBox[{"order", ":", "Omega_c"}]}], "=", 
     RowBox[{"delta_a", "+", "delta_b", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "2"}], ")"}], " ", "delta_a", " ", "x", " ", 
       "delta_b"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"composedSamples", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"da", ",", "db", ",", "dc"}], "}"}], ",", 
         RowBox[{
          RowBox[{"da", "=", 
           RowBox[{"samples", "[", 
            RowBox[{"[", 
             RowBox[{"k", ",", 
              RowBox[{"1", ";;", "3"}]}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"db", "=", 
           RowBox[{"samples", "[", 
            RowBox[{"[", 
             RowBox[{"k", ",", 
              RowBox[{"4", ";;", "6"}]}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"dc", "=", 
           RowBox[{"da", "+", "db", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "/", "2"}], ")"}], " ", 
             RowBox[{"Cross", "[", 
              RowBox[{"da", ",", "db"}], "]"}]}]}]}], ";", 
          "\[IndentingNewLine]", "dc"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "nSamples"}], "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mcMean", "=", 
     RowBox[{"Mean", "[", "composedSamples", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<MC mean (2nd order BCH): \>\"", ",", "mcMean"}], "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Analytic mean correction: \>\"", ",", 
      RowBox[{"meanCorr", "//", "N"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Mean error: \>\"", ",", 
      RowBox[{
       RowBox[{"Norm", "[", 
        RowBox[{"mcMean", "-", "meanCorr"}], "]"}], "//", 
       RowBox[{
        RowBox[{"ScientificForm", "[", 
         RowBox[{"#", ",", "2"}], "]"}], "&"}]}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"MC", " ", "covariance"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mcCov", "=", 
     RowBox[{"Covariance", "[", "composedSamples", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"firstOrderCov", "=", 
     RowBox[{"SigAA", "+", "SigBB", "+", "SigAB", "+", "SigBA"}]}], ";"}], 
   "  ", 
   RowBox[{"(*", 
    RowBox[{"at", " ", "first", " ", "order"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"correctedCov", "=", 
     RowBox[{"firstOrderCov", "+", "DeltaSig"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\\nFirst-order cov Frobenius err: \>\"", ",", 
      RowBox[{
       RowBox[{"Norm", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{"mcCov", "-", "firstOrderCov"}], "]"}], "]"}], "//", 
       RowBox[{
        RowBox[{"NumberForm", "[", 
         RowBox[{"#", ",", "4"}], "]"}], "&"}]}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Corrected cov Frobenius err:   \>\"", ",", 
      RowBox[{
       RowBox[{"Norm", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{"mcCov", "-", "correctedCov"}], "]"}], "]"}], "//", 
       RowBox[{
        RowBox[{"NumberForm", "[", 
         RowBox[{"#", ",", "4"}], "]"}], "&"}]}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Improvement factor: \>\"", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Norm", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"mcCov", "-", "firstOrderCov"}], "]"}], "]"}], "/", 
        RowBox[{"Norm", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"mcCov", "-", "correctedCov"}], "]"}], "]"}]}], "//", 
       RowBox[{
        RowBox[{"NumberForm", "[", 
         RowBox[{"#", ",", "3"}], "]"}], "&"}]}]}], "]"}], ";"}], 
   "\n"}]}]], "Input",
