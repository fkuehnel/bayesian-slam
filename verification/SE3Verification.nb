   RowBox[{
    RowBox[{
     RowBox[{"hat", "[", "w_", "]"}], ":=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{"-", 
          RowBox[{"w", "[", 
           RowBox[{"[", "3", "]"}], "]"}]}], ",", 
         RowBox[{"w", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"w", "[", 
          RowBox[{"[", "3", "]"}], "]"}], ",", "0", ",", 
         RowBox[{"-", 
          RowBox[{"w", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"w", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ",", 
