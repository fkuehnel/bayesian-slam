  RowBox[{
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<================================================================\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<PART 2: Rodrigues formula \[LongDash] R(Omega) = \
exp(Theta H)\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<================================================================\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Rodrigues", ":", "R"}], "=", 
     RowBox[{"I", "+", 
      RowBox[{"sin", 
       RowBox[{"(", "Theta", ")"}], " ", "H"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"cos", 
          RowBox[{"(", "Theta", ")"}]}]}], ")"}], " ", 
       RowBox[{"H", "^", "2"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Rodrigues", "[", 
      RowBox[{"th_", ",", "Hmat_"}], "]"}], ":=", 
     RowBox[{"id3", "+", 
      RowBox[{
       RowBox[{"Sin", "[", "th", "]"}], " ", "Hmat"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"Cos", "[", "th", "]"}]}], ")"}], " ", 
       RowBox[{"Hmat", ".", "Hmat"}]}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Rsym", "=", 
     RowBox[{"Rodrigues", "[", 
      RowBox[{"theta", ",", "H"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Verify", " ", 
      RowBox[{"R", "^", "T"}], " ", "R"}], "=", "I"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"RtR", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"Transpose", "[", "Rsym", "]"}], ".", "Rsym"}], "//", 
      "Simplify"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<R^T R = I: \>\"", ",", 
      RowBox[{
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"RtR", "-", "id3"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"r1", "^", "2"}], "+", 
           RowBox[{"r2", "^", "2"}], "+", 
           RowBox[{"r3", "^", "2"}]}], "==", "1"}]}], "]"}], "==", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", "3", "}"}], ",", 
         RowBox[{"{", "3", "}"}]}], "]"}]}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Verify", " ", "det", " ", "R"}], "=", "1"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"detR", "=", 
     RowBox[{
      RowBox[{"Det", "[", "Rsym", "]"}], "//", "Simplify"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<det R = 1: \>\"", ",", 
      RowBox[{
       RowBox[{"FullSimplify", "[", 
        RowBox[{"detR", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"r1", "^", "2"}], "+", 
           RowBox[{"r2", "^", "2"}], "+", 
           RowBox[{"r3", "^", "2"}]}], "==", "1"}]}], "]"}], "===", "1"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Verify", " ", "Tr", " ", "R"}], "=", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", "cos", 
       RowBox[{"(", "Theta", ")"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"trR", "=", 
     RowBox[{
      RowBox[{"Tr", "[", "Rsym", "]"}], "//", "Simplify"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Tr R = 1 + 2cos(Theta): \>\"", ",", 
      RowBox[{
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"trR", "-", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"2", " ", 
             RowBox[{"Cos", "[", "theta", "]"}]}]}], ")"}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"r1", "^", "2"}], "+", 
           RowBox[{"r2", "^", "2"}], "+", 
           RowBox[{"r3", "^", "2"}]}], "==", "1"}]}], "]"}], "===", "0"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"2", "pi", " ", "periodicity"}], "*)"}], "\[IndentingNewLine]", 
