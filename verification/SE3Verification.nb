    RowBox[{"PART", " ", "8"}], ":", 
    RowBox[{"SE", 
     RowBox[{"(", "3", ")"}], " ", "COMPOSITION", " ", "AND", " ", 
     "EXPONENTIAL", " ", "MAP"}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "==="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<\\n\\n================================================================\>\
\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<PART 8: SE(3) composition and exp/log\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<================================================================\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"SE", 
      RowBox[{"(", "3", ")"}], " ", 
      RowBox[{"element", ":", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"R", ",", "T"}], ")"}], " ", "with", " ", "T"}]}]}], "=", 
     RowBox[{"S", 
      RowBox[{"(", "Omega", ")"}], " ", "t"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Composition", ":", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"R_a", ",", "T_a"}], ")"}], ".", 
       RowBox[{"(", 
        RowBox[{"R_b", ",", "T_b"}], ")"}]}]}], "=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"R_a", " ", "R_b"}], ",", 
       RowBox[{
        RowBox[{"R_a", " ", "T_b"}], "+", "T_a"}]}], ")"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"exp", ":", 
      RowBox[{"[", 
       RowBox[{"Omega", ",", "t"}], "]"}]}], "->", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"R", 
        RowBox[{"(", "Omega", ")"}]}], ",", 
       RowBox[{"S", 
        RowBox[{"(", "Omega", ")"}], " ", "t"}]}], ")"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"log", ":", 
       RowBox[{"(", 
        RowBox[{"R", ",", "T"}], ")"}]}], "->", 
      RowBox[{
       RowBox[{"[", 
        RowBox[{"Omega", ",", 
         RowBox[{
          RowBox[{"S", "^", 
           RowBox[{"{", 
            RowBox[{"-", "1"}], "}"}]}], 
          RowBox[{"(", "Omega", ")"}], " ", "T"}]}], "]"}], " ", "where", " ",
        "Omega"}]}], "=", 
     RowBox[{"log", 
      RowBox[{"(", "R", ")"}]}]}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Smatrix", "[", "omega_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"th", "=", 
          RowBox[{"Norm", "[", "omega", "]"}]}], ",", "rr", ",", "HH", ",", 
         "RR"}], "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"th", "<", 
           RowBox[{"10", "^", 
            RowBox[{"-", "12"}]}]}], ",", 
          RowBox[{"Return", "[", "id3", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"rr", "=", 
         RowBox[{"omega", "/", "th"}]}], ";", 
        RowBox[{"HH", "=", 
         RowBox[{"hat", "[", "rr", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"RR", "=", 
         RowBox[{"id3", "+", 
          RowBox[{
           RowBox[{"Sin", "[", "th", "]"}], " ", "HH"}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"Cos", "[", "th", "]"}]}], ")"}], " ", 
           RowBox[{"HH", ".", "HH"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"id3", "+", 
         RowBox[{"HH", ".", "HH"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "/", "th"}], ")"}], 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"id3", "-", "RR"}], ")"}], ".", "HH"}]}]}]}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"SinvMatrix", "[", "omega_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"th", "=", 
          RowBox[{"Norm", "[", "omega", "]"}]}], ",", "rr", ",", "HH", ",", 
         "omx"}], "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"th", "<", 
           RowBox[{"10", "^", 
            RowBox[{"-", "12"}]}]}], ",", 
          RowBox[{"Return", "[", "id3", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"rr", "=", 
         RowBox[{"omega", "/", "th"}]}], ";", 
        RowBox[{"HH", "=", 
         RowBox[{"hat", "[", "rr", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"omx", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"th", "/", "2"}], ")"}], "/", 
          RowBox[{"Tan", "[", 
           RowBox[{"th", "/", "2"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"omx", " ", "id3"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "omx"}], ")"}], " ", 
          RowBox[{"Outer", "[", 
           RowBox[{"Times", ",", "rr", ",", "rr"}], "]"}]}], "-", 
         RowBox[{
          RowBox[{"(", 
