   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "==="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<\\n\\n================================================================\>\
\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<PART 5: BCH \[LongDash] finite Rodrigues composition \
via SU(2)\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<================================================================\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Paper", " ", 
        RowBox[{"Eq", ".", 
         RowBox[{"(", "addSO3finite", ")"}]}]}], ":", "Omega_c"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Theta_c", "/", "C"}], ")"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"a", " ", "r_a"}], "+", 
          RowBox[{"b", " ", "r_b"}], "+", 
          RowBox[{"ab", " ", "r_a", " ", "x", " ", "r_b"}]}], ")"}], " ", 
        "a"}], "=", 
       RowBox[{"tan", 
        RowBox[{"(", 
         RowBox[{"Theta_a", "/", "2"}], ")"}]}]}]}], ",", 
     RowBox[{"b", "=", 
      RowBox[{
       RowBox[{"tan", 
        RowBox[{"(", 
         RowBox[{"Theta_b", "/", "2"}], ")"}], " ", "A"}], "=", 
       RowBox[{
        RowBox[{"1", "+", 
         RowBox[{"a", "^", "2"}], "+", 
         RowBox[{"b", "^", "2"}], "+", 
         RowBox[{
          RowBox[{"a", "^", "2"}], " ", 
          RowBox[{"b", "^", "2"}], " ", "eps"}]}], "=", 
        RowBox[{"1", "-", 
         RowBox[{"ab", " ", "cos", 
          RowBox[{"(", "vartheta", ")"}]}]}]}]}]}], ",", 
     RowBox[{
      RowBox[{"cos", 
       RowBox[{"(", "vartheta", ")"}]}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"r_a", ".", "r_b"}], " ", "C"}], "=", 
       RowBox[{
        RowBox[{"sqrt", 
         RowBox[{"(", 
          RowBox[{"A", "-", 
           RowBox[{"eps", "^", "2"}]}], ")"}], " ", "tan", 
         RowBox[{"(", 
          RowBox[{"Theta_c", "/", "2"}], ")"}]}], "=", 
        RowBox[{"C", "/", "eps"}]}]}]}]}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Testing against matrix multiplication: R_c = R_a R_b, \
Omega_c = log(R_c)\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Numerical", " ", "test", " ", "cases"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"testCases", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0.3", ",", 
           RowBox[{"-", "0.5"}], ",", "0.7"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0.1", ",", "0.2", ",", 
           RowBox[{"-", "0.4"}]}], "}"}]}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"moderate", " ", "angles"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1.0", ",", "0.0", ",", "0.0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0.0", ",", "1.0", ",", "0.0"}], "}"}]}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"orthogonal", " ", "axes"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0.01", ",", "0.02", ",", 
           RowBox[{"-", "0.01"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0.03", ",", 
           RowBox[{"-", "0.01"}], ",", "0.02"}], "}"}]}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"small", " ", "angles"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"2.5", ",", "0.0", ",", "0.0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0.0", ",", "0.5", ",", "0.0"}], "}"}]}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"near", " ", "pi"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0.5", ",", "0.5", ",", "0.5"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0.5", ",", "0.5", ",", "0.5"}], "}"}]}], "}"}]}], 
      "        ", 
      RowBox[{"(*", "parallel", "*)"}], "}"}]}], ";"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", 
    RowBox[{"Rodrigues", " ", 
     RowBox[{"exp", "/", "log"}], " ", "in", " ", "Mathematica"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rodriguesExp", "[", "omega_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"th", "=", 
          RowBox[{"Norm", "[", "omega", "]"}]}], ",", "rr", ",", "HH"}], 
        "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"th", "<", 
           RowBox[{"10", "^", 
            RowBox[{"-", "12"}]}]}], ",", 
          RowBox[{"Return", "[", "id3", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"rr", "=", 
         RowBox[{"omega", "/", "th"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"HH", "=", 
         RowBox[{"hat", "[", "rr", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"id3", "+", 
         RowBox[{
          RowBox[{"Sin", "[", "th", "]"}], " ", "HH"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"Cos", "[", "th", "]"}]}], ")"}], " ", 
          RowBox[{"HH", ".", "HH"}]}]}]}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rodriguesLog", "[", "R_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"costh", ",", "th", ",", "rr", ",", "sk"}], "}"}], ",", 
       RowBox[{
        RowBox[{"costh", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Tr", "[", "R", "]"}], "-", "1"}], ")"}], "/", "2"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"costh", "=", 
         RowBox[{"Min", "[", 
          RowBox[{"1", ",", 
           RowBox[{"Max", "[", 
            RowBox[{
             RowBox[{"-", "1"}], ",", "costh"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"th", "=", 
         RowBox[{"ArcCos", "[", "costh", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"th", "<", 
           RowBox[{"10", "^", 
            RowBox[{"-", "12"}]}]}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"0.", ",", "0.", ",", "0."}], "}"}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"sk", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"R", "-", 
            RowBox[{"Transpose", "[", "R", "]"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", 
            RowBox[{"Sin", "[", "th", "]"}]}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"rr", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"sk", "[", 
            RowBox[{"[", 
             RowBox[{"3", ",", "2"}], "]"}], "]"}], ",", 
           RowBox[{"sk", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "3"}], "]"}], "]"}], ",", 
           RowBox[{"sk", "[", 
            RowBox[{"[", 
             RowBox[{"2", ",", "1"}], "]"}], "]"}]}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"th", " ", "rr"}]}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"bchCompose", "[", 
      RowBox[{"omA_", ",", "omB_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "thA", ",", "thB", ",", "rA", ",", "rB", ",", "a", ",", "b", ",", 
         "cosv", ",", "bigA", ",", "eps", ",", "Csq", ",", "bigC", ",", "thC",
          ",", "dir", ",", "pf"}], "}"}], ",", 
       RowBox[{
        RowBox[{"thA", "=", 
         RowBox[{"Norm", "[", "omA", "]"}]}], ";", 
        RowBox[{"thB", "=", 
         RowBox[{"Norm", "[", "omB", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"thA", "<", 
           RowBox[{"10", "^", 
            RowBox[{"-", "12"}]}]}], ",", 
          RowBox[{"Return", "[", "omB", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"thB", "<", 
           RowBox[{"10", "^", 
            RowBox[{"-", "12"}]}]}], ",", 
          RowBox[{"Return", "[", "omA", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"rA", "=", 
         RowBox[{"omA", "/", "thA"}]}], ";", 
        RowBox[{"rB", "=", 
         RowBox[{"omB", "/", "thB"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"a", "=", 
         RowBox[{"Tan", "[", 
          RowBox[{"thA", "/", "2"}], "]"}]}], ";", 
        RowBox[{"b", "=", 
         RowBox[{"Tan", "[", 
          RowBox[{"thB", "/", "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"cosv", "=", 
         RowBox[{"rA", ".", "rB"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"bigA", "=", 
         RowBox[{"1", "+", 
          RowBox[{"a", "^", "2"}], "+", 
          RowBox[{"b", "^", "2"}], "+", 
          RowBox[{
           RowBox[{"a", "^", "2"}], " ", 
           RowBox[{"b", "^", "2"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"eps", "=", 
         RowBox[{"1", "-", 
          RowBox[{"a", " ", "b", " ", "cosv"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Csq", "=", 
         RowBox[{"Max", "[", 
          RowBox[{"0", ",", 
           RowBox[{"bigA", "-", 
            RowBox[{"eps", "^", "2"}]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"bigC", "=", 
         RowBox[{"Sqrt", "[", "Csq", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"thC", "=", 
         RowBox[{"2", " ", 
          RowBox[{"ArcTan", "[", 
           RowBox[{"eps", ",", "bigC"}], "]"}]}]}], ";", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{
           RowBox[{"Mathematica", " ", 
            RowBox[{"ArcTan", "[", 
             RowBox[{"x", ",", "y"}], "]"}]}], "=", 
           RowBox[{"atan2", 
            RowBox[{"(", 
             RowBox[{"y", ",", "x"}], ")"}]}]}], ",", 
          RowBox[{"so", " ", "this", " ", "gives", " ", "atan2", 
           RowBox[{"(", 
            RowBox[{"C", ",", "eps"}], ")"}]}]}], "*)"}], 
        RowBox[{"dir", "=", 
         RowBox[{
          RowBox[{"a", " ", "rA"}], "+", 
          RowBox[{"b", " ", "rB"}], "+", 
          RowBox[{"a", " ", "b", " ", 
           RowBox[{"Cross", "[", 
            RowBox[{"rA", ",", "rB"}], "]"}]}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"bigC", "<", 
           RowBox[{"10", "^", 
            RowBox[{"-", "12"}]}]}], ",", 
          RowBox[{"pf", "=", 
           RowBox[{"2", "/", "eps"}]}], ",", 
          RowBox[{"pf", "=", 
           RowBox[{"thC", "/", "bigC"}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"omC", "=", 
         RowBox[{"pf", " ", "dir"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Phase", " ", "reflection", " ", "if"}], "|", "Omega_c", "|",
           " ", 
          RowBox[{">", "pi"}]}], "*)"}], 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Norm", "[", "omC", "]"}], ">", 
           RowBox[{"Pi", "+", 
            RowBox[{"10", "^", 
             RowBox[{"-", "10"}]}]}]}], ",", 
          RowBox[{"omC", "=", 
           RowBox[{
            RowBox[{"-", "omC"}], " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", " ", "Pi"}], "-", 
               RowBox[{"Norm", "[", "omC", "]"}]}], ")"}], "/", 
             RowBox[{"Norm", "[", "omC", "]"}]}]}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", "omC"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\nTest: BCH formula vs matrix log(R_a R_b)\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"omA", ",", "omB"}], "}"}], "=", 
        RowBox[{"testCases", "[", 
         RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Ra", "=", 
        RowBox[{"rodriguesExp", "[", "omA", "]"}]}], ";", 
       RowBox[{"Rb", "=", 
        RowBox[{"rodriguesExp", "[", "omB", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Rc", "=", 
        RowBox[{"Ra", ".", "Rb"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"omMatrix", "=", 
        RowBox[{"rodriguesLog", "[", "Rc", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"omBCH", "=", 
        RowBox[{"bchCompose", "[", 
         RowBox[{"omA", ",", "omB"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Compare", " ", "rotation", " ", "matrices"}], "*)"}], 
       RowBox[{"RcBCH", "=", 
        RowBox[{"rodriguesExp", "[", "omBCH", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"err", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"Abs", "[", 
          RowBox[{"Flatten", "[", 
           RowBox[{"Rc", "-", "RcBCH"}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<  Case \>\"", ",", "k", 
         ",", "\"\<: max |R_matrix - R_BCH| = \>\"", ",", 
         RowBox[{"ScientificForm", "[", 
          RowBox[{"err", ",", "3"}], "]"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", 
        RowBox[{"Length", "[", "testCases", "]"}]}], "}"}]}], "]"}], 
    ";"}]}]}]], "Input",
