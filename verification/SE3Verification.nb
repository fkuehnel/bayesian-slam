    ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<================================================================\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"J_wr", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}], "I"}], "+", 
      RowBox[{"x", " ", "r", " ", 
       RowBox[{"r", "^", "T"}]}], "+", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "2"}], ")"}], "[", "Omega", "]"}], "_x"}]}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"J_wl", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}], "I"}], "+", 
      RowBox[{"x", " ", "r", " ", 
       RowBox[{"r", "^", "T"}]}], "-", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "2"}], ")"}], "[", "Omega", "]"}], "_x"}]}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"where", " ", "1"}], "-", "x"}], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Theta", "/", "2"}], ")"}], " ", "cot", 
      RowBox[{"(", 
       RowBox[{"Theta", "/", "2"}], ")"}], " ", "as", " ", "above"}]}], 
    "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Jwr", "=", 
     RowBox[{
      RowBox[{"oneMinusX", " ", "id3"}], "+", 
      RowBox[{"xVal", " ", "rrT"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"theta", "/", "2"}], ")"}], " ", "H"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Jwl", "=", 
     RowBox[{
      RowBox[{"oneMinusX", " ", "id3"}], "+", 
      RowBox[{"xVal", " ", "rrT"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"theta", "/", "2"}], ")"}], " ", "H"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
