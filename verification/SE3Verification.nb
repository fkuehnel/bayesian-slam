              RowBox[{"omA", "*", "0"}], "+", 
              RowBox[{"h", " ", 
               RowBox[{"UnitVector", "[", 
                RowBox[{"3", ",", "j"}], "]"}]}]}]}], "]"}], "-", 
           RowBox[{"bchCompose", "[", 
