  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"PART", " ", "2"}], ":", 
     RowBox[{"RODRIGUES", " ", "FORMULA"}]}], "\[LongDash]", 
    RowBox[{"exp", 
     RowBox[{"(", 
      RowBox[{"Theta", " ", "H"}], ")"}]}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
