    "Verify", " ", "numerically", " ", "via", " ", "finite", " ", 
     "differences"}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"omA", "=", 
     RowBox[{"{", 
      RowBox[{"0.7", ",", 
       RowBox[{"-", "0.4"}], ",", "1.2"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"h", "=", 
     RowBox[{"10", "^", 
      RowBox[{"-", "7"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"JwrFD", "=", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"bchCompose", "[", 
            RowBox[{"omA", ",", 
