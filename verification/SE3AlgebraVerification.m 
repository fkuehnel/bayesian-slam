Do[
  omA = s rA; omB = s rB;
  exact = bchCompose[omA, omB];
  bch2 = omA + omB + (1/2) Cross[omA, omB];
  bch3 = bch2 + (1/12)(Cross[omA, Cross[omA, omB]] + Cross[omB, Cross[omB, omA]]);
  e2 = Norm[exact - bch2];
  e3 = Norm[exact - bch3];
  Print[PaddedForm[s, {7, 3}], "  ",
    ScientificForm[Norm[exact], 4], "  ",
    ScientificForm[e2, 4], "  ",
