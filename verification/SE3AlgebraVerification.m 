(*  PART 14: SECOND-ORDER COVARIANCE CORRECTION (Paper Appendix D)          *)
(* ======================================================================== *)

Print["\n\n================================================================"];
Print["PART 14: Second-order covariance correction"];
Print["================================================================"];

(* The BCH map: Omega_c = Omega_a + Omega_b + (1/2) Omega_a x Omega_b + ...
   
   For zero-mean perturbations delta_a, delta_b:
   <Omega_c> = (1/2) <delta_a x delta_b> = (1/2) eps_{i,alpha,beta} Sigma_ab_{alpha,beta}
   
   Covariance correction (rotational block):
   Delta Sigma_ij = (1/4) eps_{i,ab} eps_{j,cd} [Sigma_aa_{ac} Sigma_bb_{bd} + Sigma_ab_{ad} Sigma_ba_{bc}]
   
   (using Isserlis' theorem for Gaussian perturbations — fourth cumulant = 0) *)

(* Test with specific covariances *)
SigAA = {{0.04, 0.01, -0.005}, {0.01, 0.03, 0.008}, {-0.005, 0.008, 0.05}};
SigBB = {{0.03, -0.01, 0.002}, {-0.01, 0.06, -0.003}, {0.002, -0.003, 0.04}};
SigAB = {{0.005, -0.002, 0.001}, {0.003, -0.004, 0.002}, {-0.001, 0.003, -0.002}};
SigBA = Transpose[SigAB];

(* Mean correction *)
LeviCivita[i_, j_, k_] := Signature[{i, j, k}];

meanCorr = Table[
  (1/2) Sum[LeviCivita[i, a, b] SigAB[[a, b]], {a, 3}, {b, 3}],
  {i, 3}
];
Print["Second-order mean correction: ", meanCorr // N];
Print["(Should be nonzero if Sigma_ab has antisymmetric part)"];

(* Covariance correction *)
DeltaSig = Table[
  (1/4) Sum[
    LeviCivita[i, a, b] LeviCivita[j, c, d] (
      SigAA[[a, c]] SigBB[[b, d]] + SigAB[[a, d]] SigBA[[b, c]]
    ),
    {a, 3}, {b, 3}, {c, 3}, {d, 3}
  ],
  {i, 3}, {j, 3}
];

Print["\nSecond-order covariance correction (rotational block):"];
Print[DeltaSig // N // MatrixForm];

(* Verify symmetry *)
Print["Symmetric: ", DeltaSig == Transpose[DeltaSig]];

(* Monte Carlo verification *)
Print["\n--- Monte Carlo verification ---"];
nSamples = 100000;

(* Build joint covariance *)
SigJoint = ArrayFlatten[{{SigAA, SigAB}, {SigBA, SigBB}}];
cholJ = CholeskyDecomposition[SigJoint] // Transpose;

(* Sample *)
SeedRandom[42];
samples = Table[cholJ . RandomVariate[NormalDistribution[], 6], {nSamples}];

(* Compose via BCH second-order: Omega_c = delta_a + delta_b + (1/2) delta_a x delta_b *)
composedSamples = Table[
  Module[{da, db, dc},
    da = samples[[k, 1 ;; 3]];
    db = samples[[k, 4 ;; 6]];
    dc = da + db + (1/2) Cross[da, db];
    dc
  ],
  {k, nSamples}
];

mcMean = Mean[composedSamples];
Print["MC mean (2nd order BCH): ", mcMean];
Print["Analytic mean correction: ", meanCorr // N];
Print["Mean error: ", Norm[mcMean - meanCorr] // ScientificForm[#, 2] &];

(* MC covariance *)
mcCov = Covariance[composedSamples];
firstOrderCov = SigAA + SigBB + SigAB + SigBA;  (* at first order *)
correctedCov = firstOrderCov + DeltaSig;

Print["\nFirst-order cov Frobenius err: ",
  Norm[Flatten[mcCov - firstOrderCov]] // NumberForm[#, 4] &];
Print["Corrected cov Frobenius err:   ",
  Norm[Flatten[mcCov - correctedCov]] // NumberForm[#, 4] &];
Print["Improvement factor: ",
  Norm[Flatten[mcCov - firstOrderCov]] / Norm[Flatten[mcCov - correctedCov]] // NumberForm[#, 3] &];


