Print["PART 13: BCH series truncation — order analysis"];
Print["================================================================"];

(* BCH second-order: Omega_c ≈ Omega_a + Omega_b + (1/2) Omega_a × Omega_b *)
(* BCH third-order: + (1/12)(Omega_a×(Omega_a×Omega_b) + Omega_b×(Omega_b×Omega_a)) *)

scales = {0.001, 0.003, 0.01, 0.03, 0.1, 0.3, 1.0};
rA = Normalize[{3., -1., 2.}]; rB = Normalize[{-1., 2., 1.}];

Print[PaddedForm["scale", 7], "  ",
  PaddedForm["exact", 12], "  ",
  PaddedForm["err2nd", 12], "  ",
